default_platform(:ios)

platform :ios do
  desc "Build iOS only (no upload) — for local verification"
  lane :build do
    xcodebuild(
      scheme: "BezNomera",
      project: "BezNomera.xcodeproj",
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator",
      build: true,
      xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO",
      xcpretty_output: "simple",
      xcpretty_args: "--no-color"
    )
  end

  desc "Build and upload iOS to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: false,
      force_for_new_devices: true
    )

    current_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.paulislava.beznomera"
    )

    increment_build_number(
      build_number: current_build + 1,
      xcodeproj: "BezNomera.xcodeproj"
    )

    build_app(
      scheme: "BezNomera",
      project: "BezNomera.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      destination: "generic/platform=iOS",
      output_directory: "./build",
      output_name: "BezNomera",
      clean: true,
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.paulislava.beznomera" => "match AppStore com.paulislava.beznomera"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.paulislava.beznomera",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    clean_build_artifacts
  end
end